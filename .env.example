# API Configuration Template
# 请将此文件重命名为 .env 并填入您的真实密钥

# ==========================================
# Google Gemini 配置 (推荐)
# ==========================================
# 获取地址: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini OpenAI 兼容端点 (保持默认即可)
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#AI_MODEL=gemini-3.1-flash-lite-preview
AI_MODEL=gemini-2.5-flash-lite

# ==========================================
# OpenAI 配置 (可选)
# ==========================================
# OPENAI_API_KEY=sk-xxxx
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# ==========================================
# 其他配置
# ==========================================
# 运行模式: auto (自动) / interactive (交互)
EXECUTION_MODE=auto
# 无论是否显示思考过程都会消耗token
SHOW_THOUGHTS = 1
# 网络代理
#AI_PROXY=http://127.0.0.1:10808
# ==========================================
# 调试与审计 (Debug & Audit)
# ==========================================
# 是否保存所有发送给 AI 的 Prompt (1: 保存到 artifacts/logs/prompts/, 0: 不保存)
SAVE_PROMPTS=0

# 是否显示详细调试日志 (1: 显示 DEBUG: 信息, 0: 仅显示 INFO/WARN)
TEST_DEBUG=0

# ==========================================
# 业务预警配置 (Business Alert Configuration)
# ==========================================
# 瞬时异常捕捉关键字 (逗号分隔)
ERROR_KEYWORDS=数据库操作失败,网络异常,权限不足,系统繁忙,未知错误,Exception